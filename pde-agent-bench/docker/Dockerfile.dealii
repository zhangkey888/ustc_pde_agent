# ============================================================================
# pdebench/docker/Dockerfile.dealii
#
# 基础镜像：deal.II 官方镜像（Ubuntu 22.04 + deal.II 9.7）
# 作用：提供 deal.II C++ 库环境，用于运行 deal.II oracle 和编译/执行 agent C++ solver
#
# 构建（单平台，本机架构）：
#   docker build -t pdebench/dealii:latest -f docker/Dockerfile.dealii .
#
# 构建（多架构，同时支持 amd64 + arm64，需要 buildx）：
#   docker buildx build \
#     --platform linux/amd64,linux/arm64 \
#     -t pdebench/dealii:latest \
#     -f docker/Dockerfile.dealii . --push
#
# ⚠️  注意：dealii/dealii:v9.7.1-jammy 官方镜像目前仅提供 linux/amd64。
#     在 Apple Silicon Mac（arm64）上运行 amd64 镜像时：
#       - Docker Desktop 会通过 Rosetta 2 转译，比 QEMU 快 3-10x
#       - docker_bridge.py 已自动在 arm64 宿主机上加 --platform linux/amd64
#     如需原生 arm64 速度，需基于 arm64 Ubuntu 22.04 手动编译 deal.II。
#
# 本镜像策略：
#   - 不将项目代码烧入镜像，代码通过 volume 挂载（-v）在运行时注入
#   - oracle C++ 二进制在 docker build 阶段预编译，节省运行时编译开销
# ============================================================================

FROM dealii/dealii:v9.7.1-jammy

# ------ 切换到 root 以安装系统依赖（v9.7 镜像默认非 root 用户）-----------------
USER root

# ------ 替换 apt 源为国内镜像（避免 ports.ubuntu.com 在国内被墙）--------------
RUN sed -i \
      's|http://ports.ubuntu.com/ubuntu-ports|http://mirrors.aliyun.com/ubuntu-ports|g; \
       s|http://archive.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g; \
       s|http://security.ubuntu.com/ubuntu|http://mirrors.aliyun.com/ubuntu|g' \
      /etc/apt/sources.list

# ------ 系统依赖 ---------------------------------------------------------------
# python3-gmsh: gmsh pip wheel 仅支持 linux/x86_64，Apple Silicon (ARM64) 宿主机
# 通过 Rosetta 运行 amd64 容器时 pip 平台检测异常，统一改用 apt 系统包。
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip \
        nlohmann-json3-dev \
        python3-gmsh \
        && \
    rm -rf /var/lib/apt/lists/*

# ------ Python 依赖（与宿主机 executor 解析 npz 输出一致）-----------------------
RUN pip3 install --no-cache-dir numpy scipy sympy

# ------ 工作目录 ---------------------------------------------------------------
WORKDIR /workspace

# ------ 预编译 oracle 二进制（build 阶段完成，避免运行时 cmake/make）--------------
# 将项目代码临时 COPY 进来仅用于预编译，运行时通过 volume 挂载实际代码
COPY pdebench/ /tmp/pdebench_build/pdebench/
COPY pyproject.toml /tmp/pdebench_build/

RUN pip3 install --no-cache-dir -e /tmp/pdebench_build 2>/dev/null || true && \
    python3 - <<'EOF'
import sys
sys.path.insert(0, "/tmp/pdebench_build")
from pdebench.oracle.dealii_oracle.common import ensure_built
from pathlib import Path
src = Path("/tmp/pdebench_build/pdebench/oracle/dealii_oracle/programs")
bld = Path("/opt/dealii_oracle_build")
bld.mkdir(parents=True, exist_ok=True)
for pde in [
    "poisson", "heat", "helmholtz", "stokes", "navier_stokes",
    "convection_diffusion", "biharmonic", "linear_elasticity",
    "reaction_diffusion",
]:
    print(f"[precompile] {pde} ...", flush=True)
    ensure_built(src, bld, pde)
print("[precompile] All oracle binaries built.", flush=True)
EOF

# 将预编译二进制移到固定路径，运行时不再需要源码
ENV DEALII_ORACLE_PREBUILT_DIR=/opt/dealii_oracle_build

# ------ 清理临时构建文件 -------------------------------------------------------
RUN rm -rf /tmp/pdebench_build

# ------ 默认入口 ---------------------------------------------------------------
# 运行时由 docker_bridge.py 覆盖为：
#   python -m pdebench.oracle.runner <case.json> <outdir> dealii
CMD ["python3", "--version"]
