{"id": "heat_kappa_low_background_manufactured", "pde_classification": {"equation_type": "heat", "math_type": ["parabolic"]}, "pde": {"type": "heat", "description": "Manufactured with low-background kappa plus localized bump (tests near-degenerate coefficient regions)", "coefficients": {"kappa": {"type": "expr", "expr": "0.2 + exp(-120*((x-0.55)**2 + (y-0.45)**2))"}}, "manufactured_solution": {"u": "exp(-t)*sin(pi*x)*sin(pi*y)"}, "time": {"t0": 0.0, "t_end": 0.1, "dt": 0.01, "scheme": "backward_euler"}, "source_term": "(pi*((240*x - 132.0)*sin(pi*y)*cos(pi*x) + (240*y - 108.0)*sin(pi*x)*cos(pi*y) + 2*pi*(0.2*exp(120*(x - 0.55)**2 + 120*(y - 0.45)**2) + 1)*sin(pi*x)*sin(pi*y))*exp(t) - exp(t + 120*(x - 0.55)**2 + 120*(y - 0.45)**2)*sin(pi*x)*sin(pi*y))*exp(-2*t - 120*(x - 0.55)**2 - 120*(y - 0.45)**2)"}, "domain": {"type": "unit_square"}, "bc": {"dirichlet": {"on": "all", "value": "u"}}, "output": {"format": "npz", "field": "scalar", "grid": {"bbox": [0, 1, 0, 1], "nx": 50, "ny": 50}}, "agent_knobs": [{"name": "mesh_resolution", "description": "Control spatial discretization fidelity"}, {"name": "dt", "description": "Time step size controlling accuracy vs runtime"}, {"name": "ksp_type", "description": "Linear solver choice"}, {"name": "pc_type", "description": "Preconditioner choice"}], "evaluation_config": {"target_metric": "rel_L2_grid", "timeout_sec": 300, "tolerance": 10, "accuracy_tolerance": 10, "time_tolerance": 3}}