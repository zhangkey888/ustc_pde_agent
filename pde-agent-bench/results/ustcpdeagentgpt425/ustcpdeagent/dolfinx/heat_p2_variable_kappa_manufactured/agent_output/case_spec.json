{"id": "heat_p2_variable_kappa_manufactured", "pde_classification": {"equation_type": "heat", "math_type": ["parabolic"]}, "pde": {"type": "heat", "description": "P2 elements with variable kappa (tests p-refinement under heterogeneity)", "coefficients": {"kappa": {"type": "expr", "expr": "1 + 0.4*sin(2*pi*x)*sin(2*pi*y)"}}, "manufactured_solution": {"u": "exp(-t)*sin(2*pi*x)*sin(2*pi*y)"}, "time": {"t0": 0.0, "t_end": 0.06, "dt": 0.01, "scheme": "backward_euler"}, "source_term": "(8*pi**2*(0.4*sin(2*pi*x)*sin(2*pi*y) + 1)*sin(2*pi*x)*sin(2*pi*y) - 1.6*pi**2*sin(2*pi*x)**2*cos(2*pi*y)**2 - sin(2*pi*x)*sin(2*pi*y) - 1.6*pi**2*sin(2*pi*y)**2*cos(2*pi*x)**2)*exp(-t)"}, "domain": {"type": "unit_square"}, "bc": {"dirichlet": {"on": "all", "value": "u"}}, "output": {"format": "npz", "field": "scalar", "grid": {"bbox": [0, 1, 0, 1], "nx": 50, "ny": 50}}, "agent_knobs": [{"name": "mesh_resolution", "description": "Control spatial discretization fidelity"}, {"name": "element_degree", "description": "Polynomial degree of the finite element space"}, {"name": "dt", "description": "Time step size controlling accuracy vs runtime"}, {"name": "ksp_type", "description": "Linear solver choice"}, {"name": "pc_type", "description": "Preconditioner choice"}], "evaluation_config": {"target_metric": "rel_L2_grid", "timeout_sec": 300, "tolerance": 10, "accuracy_tolerance": 10, "time_tolerance": 3}}