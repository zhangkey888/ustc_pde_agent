{"id": "heat_kappa_local_peak_manufactured", "pde_classification": {"equation_type": "heat", "math_type": ["parabolic"]}, "pde": {"type": "heat", "description": "Manufactured with localized high-kappa peak (tests local stiffness under diffusion)", "coefficients": {"kappa": {"type": "expr", "expr": "1 + 30*exp(-150*((x-0.35)**2 + (y-0.65)**2))"}}, "manufactured_solution": {"u": "exp(-t)*sin(pi*x)*sin(2*pi*y)"}, "time": {"t0": 0.0, "t_end": 0.1, "dt": 0.01, "scheme": "backward_euler"}, "source_term": "(5*pi*((1800*x - 630.0)*sin(2*pi*y)*cos(pi*x) + (3600*y - 2340.0)*sin(pi*x)*cos(2*pi*y) + pi*(exp(150*(x - 0.35)**2 + 150*(y - 0.65)**2) + 30)*sin(pi*x)*sin(2*pi*y))*exp(t) - exp(t + 150*(x - 0.35)**2 + 150*(y - 0.65)**2)*sin(pi*x)*sin(2*pi*y))*exp(-2*t - 150*(x - 0.35)**2 - 150*(y - 0.65)**2)"}, "domain": {"type": "unit_square"}, "bc": {"dirichlet": {"on": "all", "value": "u"}}, "output": {"format": "npz", "field": "scalar", "grid": {"bbox": [0, 1, 0, 1], "nx": 50, "ny": 50}}, "agent_knobs": [{"name": "mesh_resolution", "description": "Control spatial discretization fidelity"}, {"name": "dt", "description": "Time step size controlling accuracy vs runtime"}, {"name": "ksp_type", "description": "Linear solver choice"}, {"name": "pc_type", "description": "Preconditioner choice"}], "evaluation_config": {"target_metric": "rel_L2_grid", "timeout_sec": 300, "tolerance": 10, "accuracy_tolerance": 10, "time_tolerance": 3}}