{
  "id": "stokes_quadrilateral_mesh",
  "pde_classification": {
    "equation_type": "stokes",
    "math_type": [
      "incompressible_flow"
    ]
  },
  "oracle_config": {
    "pde": {
      "type": "stokes",
      "description": "Stokes on quadrilateral mesh (tests discretization choice)",
      "pde_params": {
        "nu": 1.0
      },
      "manufactured_solution": {
        "u": [
          "pi*cos(pi*y)*sin(pi*x)",
          "-pi*cos(pi*x)*sin(pi*y)"
        ],
        "p": "cos(pi*x)*cos(pi*y)"
      }
    },
    "domain": {
      "type": "unit_square"
    },
    "mesh": {
      "resolution": 64,
      "cell_type": "quadrilateral"
    },
    "fem": {
      "degree_u": 2,
      "degree_p": 1
    },
    "bc": {
      "dirichlet": {
        "on": "all",
        "value": "u"
      }
    },
    "output": {
      "format": "npz",
      "field": "velocity_magnitude",
      "grid": {
        "bbox": [
          0,
          1,
          0,
          1
        ],
        "nx": 100,
        "ny": 100
      }
    },
    "oracle_solver": {
      "ksp_type": "minres",
      "pc_type": "hypre",
      "rtol": 1e-10,
      "pressure_fixing": "point"
    }
  },
  "evaluation_config": {
    "target_metric": "rel_L2_grid",
    "timeout_sec": 300,
    "tolerance": 10,
    "accuracy_tolerance": 10,
    "time_tolerance": 3,
    "target_error": 0.01
  },
  "agent_knobs": [
    {
      "name": "mesh_resolution",
      "description": "Spatial mesh resolution controlling accuracy vs runtime"
    },
    {
      "name": "degree_u/degree_p",
      "description": "Velocity/pressure element degrees (stable mixed pair selection)"
    },
    {
      "name": "pc_type",
      "description": "Preconditioner choice for saddle-point systems"
    },
    {
      "name": "ksp_type",
      "description": "Krylov solver choice for saddle-point systems"
    },
    {
      "name": "rtol",
      "description": "Linear solver relative tolerance"
    },
    {
      "name": "pressure_fixing",
      "description": "Pressure nullspace handling (e.g., point or none)"
    }
  ],
  "baseline": {
    "error_ref": 0.01,
    "time_ref": 10.0,
    "description": "Oracle baseline performance"
  },
  "difficulty_tiers": {
    "accuracy": {
      "level_1": {
        "target_error": 1.0,
        "name": "Low/Engineering"
      },
      "level_2": {
        "target_error": 0.01,
        "name": "Medium/Standard"
      },
      "level_3": {
        "target_error": 0.0001,
        "name": "High/Scientific"
      }
    },
    "speed": {
      "fast": {
        "time_budget": 1.0,
        "name": "Real-time"
      },
      "medium": {
        "time_budget": 10.0,
        "name": "Interactive"
      },
      "slow": {
        "time_budget": 100.0,
        "name": "Batch"
      }
    }
  }
}