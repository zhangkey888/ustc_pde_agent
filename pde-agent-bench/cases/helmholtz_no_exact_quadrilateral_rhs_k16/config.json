{
  "id": "helmholtz_no_exact_quadrilateral_rhs_k16",
  "pde_classification": {
    "equation_type": "helmholtz",
    "math_type": [
      "elliptic"
    ]
  },
  "oracle_config": {
    "pde": {
      "type": "helmholtz",
      "description": "No-exact: quadrilateral mesh with oscillatory source (tests discretization choice for indefinite operator)",
      "pde_params": {
        "k": 16.0
      },
      "source_term": "sin(6*pi*x)*cos(5*pi*y)"
    },
    "domain": {
      "type": "unit_square"
    },
    "mesh": {
      "resolution": 150,
      "cell_type": "quadrilateral"
    },
    "fem": {
      "family": "Lagrange",
      "degree": 1
    },
    "bc": {
      "dirichlet": {
        "on": "all",
        "value": "0.0"
      }
    },
    "output": {
      "format": "npz",
      "field": "scalar",
      "grid": {
        "bbox": [
          0,
          1,
          0,
          1
        ],
        "nx": 50,
        "ny": 50
      }
    },
    "oracle_solver": {
      "ksp_type": "gmres",
      "pc_type": "ilu",
      "rtol": 1e-10,
      "atol": 1e-12
    },
    "reference_config": {
      "mesh": {
        "resolution": 300,
        "cell_type": "quadrilateral"
      },
      "fem": {
        "family": "Lagrange",
        "degree": 2
      },
      "oracle_solver": {
        "ksp_type": "preonly",
        "pc_type": "lu",
        "rtol": 1e-12,
        "atol": 1e-14
      }
    }
  },
  "evaluation_config": {
    "target_metric": "rel_L2_grid",
    "timeout_sec": 300,
    "tolerance": 10,
    "accuracy_tolerance": 10,
    "time_tolerance": 3,
    "target_error": 0.01
  },
  "agent_knobs": [
    {
      "name": "mesh_resolution",
