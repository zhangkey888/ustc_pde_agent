{
  "id": "navier_stokes_low_re",
  "pde_classification": {
    "equation_type": "navier_stokes",
    "math_type": [
      "incompressible_flow"
    ]
  },
  "oracle_config": {
    "pde": {
      "type": "navier_stokes",
      "description": "Low Reynolds (high viscosity) steady incompressible Navier-Stokes",
      "pde_params": {
        "nu": 1.0
      },
      "manufactured_solution": {
        "u": [
          "pi*cos(pi*y)*sin(pi*x)",
          "-pi*cos(pi*x)*sin(pi*y)"
        ],
        "p": "cos(pi*x)*cos(pi*y)"
      }
    },
    "domain": {
      "type": "unit_square"
    },
    "mesh": {
      "resolution": 48,
      "cell_type": "triangle"
    },
    "fem": {
      "degree_u": 2,
      "degree_p": 1
    },
    "bc": {
      "dirichlet": {
        "on": "all",
        "value": "u"
      }
    },
    "output": {
      "format": "npz",
      "field": "velocity_magnitude",
      "grid": {
        "bbox": [
          0,
          1,
          0,
          1
        ],
        "nx": 50,
        "ny": 50
      }
    },
    "oracle_solver": {
      "rtol": 1e-10,
      "atol": 1e-12,
      "max_it": 30
    }
  },
  "evaluation_config": {
    "target_metric": "rel_L2_grid",
    "timeout_sec": 300,
    "tolerance": 10,
    "accuracy_tolerance": 10,
    "time_tolerance": 3,
    "target_error": 0.01
  },
  "agent_knobs": [
    {
      "name": "mesh_resolution",
      "description": "Control spatial discretization fidelity"
    },
    {
      "name": "degree_u/degree_p",
      "description": "Velocity/pressure element degrees (stable mixed pair selection)"
    },
    {
      "name": "newton_rtol",
      "description": "Newton convergence tolerance affecting accuracy/robustness"
    }
  ],
  "baseline": {
    "error_ref": 0.01,
    "time_ref": 10.0,
    "description": "Oracle baseline performance"
  },
  "difficulty_tiers": {
    "accuracy": {
      "level_1": {
        "target_error": 1.0,
        "name": "Low/Engineering"
      },
      "level_2": {
        "target_error": 0.01,
        "name": "Medium/Standard"
      },
      "level_3": {
        "target_error": 0.0001,
        "name": "High/Scientific"
      }
    },
    "speed": {
      "fast": {
        "time_budget": 1.0,
        "name": "Real-time"
      },
      "medium": {
        "time_budget": 10.0,
        "name": "Interactive"
      },
      "slow": {
        "time_budget": 100.0,
        "name": "Batch"
      }
    }
  }
}