{
  "id": "convdiff_mixed_quadrilateral_supg_upwind2",
  "pde_classification": {
    "equation_type": "convection_diffusion",
    "math_type": [
      "mixed_type"
    ]
  },
  "oracle_config": {
    "pde": {
      "type": "convection_diffusion",
      "description": "Mixed-type on quadrilateral mesh with stronger SUPG (tests discretization choice)",
      "pde_params": {
        "epsilon": 0.005,
        "beta": [
          18.0,
          6.0
        ],
        "stabilization": "supg"
      },
      "manufactured_solution": {
        "u": "sin(pi*x)*sin(pi*y)"
      }
    },
    "domain": {
      "type": "unit_square"
    },
    "mesh": {
      "resolution": 180,
      "cell_type": "quadrilateral"
    },
    "fem": {
      "family": "Lagrange",
      "degree": 1
    },
    "bc": {
      "dirichlet": {
        "on": "all",
        "value": "u"
      }
    },
    "output": {
      "format": "npz",
      "field": "scalar",
      "grid": {
        "bbox": [
          0,
          1,
          0,
          1
        ],
        "nx": 50,
        "ny": 50
      }
    },
    "oracle_solver": {
      "ksp_type": "gmres",
      "pc_type": "ilu",
      "rtol": 1e-10,
      "stabilization": "supg",
      "upwind_parameter": 2.0
    }
  },
  "evaluation_config": {
    "target_metric": "rel_L2_grid",
    "timeout_sec": 300,
    "tolerance": 10,
    "accuracy_tolerance": 10,
    "time_tolerance": 3,
    "target_error": 0.01
  },
  "agent_knobs": [
    {
      "name": "stabilization",
      "description": "Stabilization strategy for convection dominance"
    },
    {
      "name": "upwind_parameter",
      "description": "Stabilization strength parameter"
    },
    {
      "name": "mesh_resolution",
      "description": "Control spatial discretization fidelity"
    },
    {
      "name": "ksp_type",
      "description": "Linear solver choice for non-symmetric systems"
    }
  ],
  "baseline": {
    "error_ref": 0.01,
    "time_ref": 10.0,
    "description": "Oracle baseline performance"
  },
  "difficulty_tiers": {
    "accuracy": {
      "level_1": {
        "target_error": 1.0,
        "name": "Low/Engineering"
      },
      "level_2": {
        "target_error": 0.01,
        "name": "Medium/Standard"
      },
      "level_3": {
        "target_error": 0.0001,
        "name": "High/Scientific"
      }
    },
    "speed": {
      "fast": {
        "time_budget": 1.0,
        "name": "Real-time"
      },
      "medium": {
        "time_budget": 10.0,
        "name": "Interactive"
      },
      "slow": {
        "time_budget": 100.0,
        "name": "Batch"
      }
    }
  }
}