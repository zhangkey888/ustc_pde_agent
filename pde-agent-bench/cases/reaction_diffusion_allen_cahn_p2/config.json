{
  "id": "reaction_diffusion_allen_cahn_p2",
  "pde_classification": {
    "equation_type": "reaction_diffusion",
    "math_type": [
      "reaction_diffusion"
    ]
  },
  "oracle_config": {
    "pde": {
      "type": "reaction_diffusion",
      "description": "Transient Allen-Cahn with P2 elements (tests p-refinement for time-dependent nonlinear)",
      "pde_params": {
        "epsilon": 0.06,
        "reaction": {
          "type": "allen_cahn",
          "lambda": 1.5
        }
      },
      "time": {
        "t0": 0.0,
        "t_end": 0.2,
        "dt": 0.005,
        "scheme": "backward_euler"
      },
      "manufactured_solution": {
        "u": "exp(-t)*(0.25*sin(2*pi*x)*sin(pi*y))"
      }
    },
    "domain": {
      "type": "unit_square"
    },
    "mesh": {
      "resolution": 90,
      "cell_type": "triangle"
    },
    "fem": {
      "family": "Lagrange",
      "degree": 2
    },
    "bc": {
      "dirichlet": {
        "on": "all",
        "value": "u"
      }
    },
    "output": {
      "format": "npz",
      "field": "scalar",
      "grid": {
        "bbox": [
          0,
          1,
          0,
          1
        ],
        "nx": 60,
        "ny": 60
      }
    },
    "oracle_solver": {
      "rtol": 1e-10,
      "atol": 1e-12,
      "max_it": 40,
      "ksp_type": "gmres",
      "pc_type": "ilu",
      "ksp_rtol": 1e-10
    }
  },
  "evaluation_config": {
    "target_metric": "rel_L2_grid",
    "timeout_sec": 300,
    "tolerance": 10,
    "accuracy_tolerance": 10,
    "time_tolerance": 3,
    "target_error": 0.01
  },
  "agent_knobs": [
    {
      "name": "mesh_resolution",
      "description": "Spatial mesh resolution"
    },
    {
      "name": "element_degree",
      "description": "FE degree for u"
    },
    {
      "name": "pc_type",
      "description": "Preconditioner choice"
    },
    {
      "name": "newton_max_it",
      "description": "Max Newton iterations"
    },
    {
      "name": "dt",
      "description": "Time step size; smaller improves accuracy but increases runtime"
    },
    {
      "name": "time_scheme",
      "description": "Time integrator (backward_euler/crank_nicolson/bdf2)"
    }
  ],
  "baseline": {
    "error_ref": 0.01,
    "time_ref": 10.0,
    "description": "Oracle baseline performance"
  },
  "difficulty_tiers": {
    "accuracy": {
      "level_1": {
        "target_error": 1.0,
        "name": "Low/Engineering"
      },
      "level_2": {
        "target_error": 0.01,
        "name": "Medium/Standard"
      },
      "level_3": {
        "target_error": 0.0001,
        "name": "High/Scientific"
      }
    },
    "speed": {
      "fast": {
        "time_budget": 1.0,
        "name": "Real-time"
      },
      "medium": {
        "time_budget": 10.0,
        "name": "Interactive"
      },
      "slow": {
        "time_budget": 100.0,
        "name": "Batch"
      }
    }
  }
}